@using Microsoft.AspNetCore.Mvc
@model AiAnyReports.ReportViewer.Models.ReportViewerModel

@{
    var viewerGroupName = Model?.GroupName ?? "SQLiteDemo";
    var viewerUrl = Url.Action("Viewer", "ReportViewer", new { groupName = viewerGroupName }) ?? $"/ReportViewer/Viewer?groupName={Uri.EscapeDataString(viewerGroupName)}";
}

<br />
<br />
<h2>My Demo Page with AiAnyReports Viewer</h2>
<br />

@* <div style="color:red; font-size:.9rem;">
    Group: @(Model?.GroupName ?? "(null)")
    | Count: @(Model?.Reports?.Count ?? 0)
</div> *@

<div style="border: 0px none #0d6bfd; padding: 0px; border-radius: 0px;">
    <iframe src="@viewerUrl"
            title="AiAnyReports Viewer"
            style="width: 100%; height: 900px; border: 0; border-radius: 0px; background: #fff;"
            loading="lazy"></iframe>
</div>

<style>
    iframe {
        display: block;
    }
</style>