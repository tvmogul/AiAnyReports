<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Libs\AiAnyReports.ReportViewer.dll" />
    <None Remove="Libs\SavedReports.aidb" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Libs\AiAnyReports.ReportViewer.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Libs\SavedReports.aidb">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.0" />
    <PackageReference Include="Microsoft.Data.Sqlite.Core" Version="10.0.6" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.2" /> 
  </ItemGroup>

  <ItemGroup>
    <Reference Include="AiAnyReports.ReportViewer">
      <HintPath>Libs\AiAnyReports.ReportViewer.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
